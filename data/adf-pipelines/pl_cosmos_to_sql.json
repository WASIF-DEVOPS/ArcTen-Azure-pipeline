{
    "name": "pl_cosmos_to_sql",
    "properties": {
        "activities": [
            {
                "name": "Copy Cosmos to SQL Staging",
                "type": "Copy",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 3,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "source": {
                        "type": "MongoDbV2Source",
                        "batchSize": 100
                    },
                    "sink": {
                        "type": "AzureSqlSink",
                        "writeBehavior": "insert",
                        "sqlWriterUseTableLock": false
                    },
                    "enableStaging": false,
                    "translator": {
                        "type": "TabularTranslator",
                        "mappings": [
                            {
                                "source": {
                                    "path": "$['_id']"
                                },
                                "sink": {
                                    "name": "_id",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['companyName']"
                                },
                                "sink": {
                                    "name": "companyName",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['email']"
                                },
                                "sink": {
                                    "name": "email",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['phone']"
                                },
                                "sink": {
                                    "name": "phone",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['productInterest']"
                                },
                                "sink": {
                                    "name": "productInterest",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['estimatedQuantity']"
                                },
                                "sink": {
                                    "name": "estimatedQuantity",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['additionalNotes']"
                                },
                                "sink": {
                                    "name": "additionalNotes",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['status']"
                                },
                                "sink": {
                                    "name": "status",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['createdAt']"
                                },
                                "sink": {
                                    "name": "createdAt",
                                    "type": "String"
                                }
                            },
                            {
                                "source": {
                                    "path": "$['updatedAt']"
                                },
                                "sink": {
                                    "name": "updatedAt",
                                    "type": "String"
                                }
                            }
                        ]
                    }
                },
                "inputs": [
                    {
                        "referenceName": "CosmosDbMongoCollection",
                        "type": "DatasetReference"
                    }
                ],
                "outputs": [
                    {
                        "referenceName": "AzureSqlStagingTable",
                        "type": "DatasetReference"
                    }
                ]
            }
        ],
        "annotations": []
    }
}
