<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Quote Request - ARCTen</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #FDFBF7;">
  <table role="presentation" style="width: 100%; border-collapse: collapse;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <table role="presentation" style="width: 100%; max-width: 600px; border-collapse: collapse;">
          
          <!-- Header -->
          <tr>
            <td style="background-color: #1C1C1C; padding: 32px 40px; border-radius: 16px 16px 0 0;">
              <table role="presentation" style="width: 100%;">
                <tr>
                  <td>
                    <h1 style="margin: 0; font-size: 24px; font-weight: 600; color: #FDFBF7; letter-spacing: 1px;">
                      ARC<span style="color: #8B7355; font-weight: 400;">Ten</span>
                    </h1>
                    <p style="margin: 8px 0 0 0; font-size: 12px; color: #FDFBF7; opacity: 0.6; text-transform: uppercase; letter-spacing: 2px;">
                      Premium Leather Manufacturing
                    </p>
                  </td>
                  <td align="right">
                    <span style="display: inline-block; background-color: #C4A052; color: #1C1C1C; font-size: 11px; font-weight: 600; padding: 6px 12px; border-radius: 20px; text-transform: uppercase; letter-spacing: 1px;">
                      New Quote
                    </span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background-color: #FFFFFF; padding: 40px;">
              <h2 style="margin: 0 0 8px 0; font-size: 28px; font-weight: 600; color: #1C1C1C;">
                New Quote Request
              </h2>
              <p style="margin: 0 0 32px 0; font-size: 15px; color: #6B6B6B; line-height: 1.5;">
                You've received a new wholesale quote request. Here are the details:
              </p>

              <!-- Quote Details Card -->
              <table role="presentation" style="width: 100%; background-color: #F8F6F3; border-radius: 12px; border-collapse: collapse;">
                <tr>
                  <td style="padding: 24px;">
                    
                    <!-- Company Name -->
                    <table role="presentation" style="width: 100%; margin-bottom: 16px;">
                      <tr>
                        <td style="width: 140px; font-size: 12px; color: #6B6B6B; text-transform: uppercase; letter-spacing: 1px; padding-bottom: 4px;">
                          Company
                        </td>
                        <td style="font-size: 16px; font-weight: 600; color: #1C1C1C; padding-bottom: 4px;">
                          <%= quote.companyName %>
                        </td>
                      </tr>
                    </table>

                    <!-- Email -->
                    <table role="presentation" style="width: 100%; margin-bottom: 16px;">
                      <tr>
                        <td style="width: 140px; font-size: 12px; color: #6B6B6B; text-transform: uppercase; letter-spacing: 1px; padding-bottom: 4px;">
                          Email
                        </td>
                        <td style="font-size: 15px; color: #1C1C1C; padding-bottom: 4px;">
                          <a href="mailto:<%= quote.email %>" style="color: #C4A052; text-decoration: none;"><%= quote.email %></a>
                        </td>
                      </tr>
                    </table>

                    <!-- Phone -->
                    <table role="presentation" style="width: 100%; margin-bottom: 16px;">
                      <tr>
                        <td style="width: 140px; font-size: 12px; color: #6B6B6B; text-transform: uppercase; letter-spacing: 1px; padding-bottom: 4px;">
                          Phone
                        </td>
                        <td style="font-size: 15px; color: #1C1C1C; padding-bottom: 4px;">
                          <a href="tel:<%= quote.phone %>" style="color: #1C1C1C; text-decoration: none;"><%= quote.phone %></a>
                        </td>
                      </tr>
                    </table>

                    <!-- Divider -->
                    <hr style="border: none; border-top: 1px solid #E8E4DE; margin: 20px 0;">

                    <!-- Product Interest -->
                    <table role="presentation" style="width: 100%; margin-bottom: 16px;">
                      <tr>
                        <td style="width: 140px; font-size: 12px; color: #6B6B6B; text-transform: uppercase; letter-spacing: 1px; padding-bottom: 4px;">
                          Product Interest
                        </td>
                        <td style="font-size: 15px; color: #1C1C1C; padding-bottom: 4px;">
                          <span style="display: inline-block; background-color: #1C1C1C; color: #FDFBF7; font-size: 12px; padding: 4px 10px; border-radius: 4px;">
                            <%= quote.productInterest.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
                          </span>
                        </td>
                      </tr>
                    </table>

                    <!-- Quantity -->
                    <table role="presentation" style="width: 100%; margin-bottom: 16px;">
                      <tr>
                        <td style="width: 140px; font-size: 12px; color: #6B6B6B; text-transform: uppercase; letter-spacing: 1px; padding-bottom: 4px;">
                          Est. Quantity
                        </td>
                        <td style="font-size: 15px; font-weight: 600; color: #C4A052; padding-bottom: 4px;">
                          <%= quote.estimatedQuantity %> units
                        </td>
                      </tr>
                    </table>

                    <% if (quote.additionalNotes) { %>
                    <!-- Divider -->
                    <hr style="border: none; border-top: 1px solid #E8E4DE; margin: 20px 0;">

                    <!-- Notes -->
                    <table role="presentation" style="width: 100%;">
                      <tr>
                        <td style="font-size: 12px; color: #6B6B6B; text-transform: uppercase; letter-spacing: 1px; padding-bottom: 8px;">
                          Additional Notes
                        </td>
                      </tr>
                      <tr>
                        <td style="font-size: 14px; color: #1C1C1C; line-height: 1.6; background-color: #FFFFFF; padding: 12px; border-radius: 8px;">
                          <%= quote.additionalNotes %>
                        </td>
                      </tr>
                    </table>
                    <% } %>

                  </td>
                </tr>
              </table>

              <!-- CTA Button -->
              <table role="presentation" style="width: 100%; margin-top: 32px;">
                <tr>
                  <td align="center">
                    <a href="<%= adminUrl %>/admin/quotes" 
                       style="display: inline-block; background-color: #1C1C1C; color: #FDFBF7; font-size: 14px; font-weight: 600; text-decoration: none; padding: 16px 32px; border-radius: 50px;">
                      View Quote Details →
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Timestamp -->
              <p style="margin: 32px 0 0 0; font-size: 12px; color: #6B6B6B; text-align: center;">
                Received on <%= new Date(quote.createdAt).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #1C1C1C; padding: 24px 40px; border-radius: 0 0 16px 16px;">
              <table role="presentation" style="width: 100%;">
                <tr>
                  <td style="font-size: 12px; color: #FDFBF7; opacity: 0.5;">
                    © <%= new Date().getFullYear() %> ARCTen Leather Manufacturing
                  </td>
                  <td align="right" style="font-size: 12px; color: #FDFBF7; opacity: 0.5;">
                    Premium Craftsmanship Since 2009
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
